<svg width="1200" height="630" viewBox="0 0 1200 630" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGrad" x1="0" y1="0" x2="1200" y2="630" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#060c1a"/>
      <stop offset="100%" stop-color="#0f172a"/>
    </linearGradient>
    <linearGradient id="blueGrad" x1="0" y1="0" x2="0" y2="630" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#1a56db" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="#1a56db" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="orangeGrad" x1="0" y1="0" x2="1200" y2="630" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#FF6B35" stop-opacity="0"/>
      <stop offset="50%" stop-color="#FF6B35" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="#FF6B35" stop-opacity="0"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bgGrad)"/>
  <rect width="1200" height="630" fill="url(#blueGrad)"/>
  <rect width="1200" height="630" fill="url(#orangeGrad)"/>

  <!-- Grid pattern -->
  <rect width="1200" height="630" fill="none" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="0" x2="0" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="60" y1="0" x2="60" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="120" y1="0" x2="120" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="180" y1="0" x2="180" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="240" y1="0" x2="240" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="300" y1="0" x2="300" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="360" y1="0" x2="360" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="420" y1="0" x2="420" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="480" y1="0" x2="480" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="540" y1="0" x2="540" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="600" y1="0" x2="600" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="660" y1="0" x2="660" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="720" y1="0" x2="720" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="780" y1="0" x2="780" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="840" y1="0" x2="840" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="900" y1="0" x2="900" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="960" y1="0" x2="960" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="1020" y1="0" x2="1020" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="1080" y1="0" x2="1080" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="1140" y1="0" x2="1140" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="1200" y1="0" x2="1200" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="0" x2="1200" y2="0" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="60" x2="1200" y2="60" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="120" x2="1200" y2="120" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="180" x2="1200" y2="180" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="240" x2="1200" y2="240" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="300" x2="1200" y2="300" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="360" x2="1200" y2="360" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="420" x2="1200" y2="420" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="480" x2="1200" y2="480" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="540" x2="1200" y2="540" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="600" x2="1200" y2="600" stroke="white" stroke-opacity="0.03" stroke-width="1"/>

  <!-- Left side content -->
  <!-- Logo -->
  <rect x="80" y="80" width="48" height="48" rx="12" fill="url(#bgGrad)"/>
  <rect x="88" y="88" width="32" height="32" rx="8" fill="#1a56db"/>
  <rect x="94" y="96" width="20" height="16" rx="2" fill="white" opacity="0.15"/>
  <rect x="96" y="99" width="12" height="2" rx="1" fill="white" opacity="0.9"/>
  <rect x="96" y="103" width="9" height="1" rx="0.5" fill="white" opacity="0.55"/>
  <rect x="96" y="105.5" width="10" height="1" rx="0.5" fill="white" opacity="0.55"/>
  <circle cx="116" cy="112" r="6" fill="#0a1628" opacity="0.85"/>
  <text x="116" y="114" text-anchor="middle" font-family="system-ui, sans-serif" font-size="5" font-weight="800" fill="white">87</text>

  <text x="80" y="170" font-family="system-ui, -apple-system, sans-serif" font-size="42" font-weight="800" fill="white">CraftlyCV</text>

  <!-- Tagline -->
  <text x="80" y="230" font-family="system-ui, -apple-system, sans-serif" font-size="28" font-weight="600" fill="white">Get Hired or Start</text>
  <text x="80" y="270" font-family="system-ui, -apple-system, sans-serif" font-size="28" font-weight="600" fill="#FF6B35">Earning in 7 Days</text>

  <!-- Sub text -->
  <text x="80" y="330" font-family="system-ui, -apple-system, sans-serif" font-size="18" fill="white" opacity="0.5">AI Resume Builder · Real Interview Practice</text>
  <text x="80" y="360" font-family="system-ui, -apple-system, sans-serif" font-size="18" fill="white" opacity="0.5">Jobs · Freelance Gigs · Income Sources</text>

  <!-- Stats -->
  <rect x="80" y="410" width="140" height="60" rx="12" fill="white" opacity="0.05"/>
  <text x="100" y="445" font-family="system-ui, -apple-system, sans-serif" font-size="28" font-weight="800" fill="white">50,000+</text>
  <text x="100" y="462" font-family="system-ui, -apple-system, sans-serif" font-size="12" fill="white" opacity="0.5">Resumes Analyzed</text>

  <rect x="240" y="410" width="140" height="60" rx="12" fill="white" opacity="0.05"/>
  <text x="260" y="445" font-family="system-ui, -apple-system, sans-serif" font-size="28" font-weight="800" fill="white">94%</text>
  <text x="260" y="462" font-family="system-ui, -apple-system, sans-serif" font-size="12" fill="white" opacity="0.5">Score Improvement</text>

  <!-- Right side - resume score demo -->
  <rect x="700" y="120" width="400" height="400" rx="20" fill="white" opacity="0.05"/>
  <text x="900" y="170" font-family="system-ui, -apple-system, sans-serif" font-size="14" font-weight="700" fill="white" opacity="0.4" text-anchor="middle">ATS SCORE</text>

  <!-- Score circle -->
  <circle cx="900" cy="300" r="100" fill="none" stroke="white" opacity="0.08" stroke-width="12"/>
  <circle cx="900" cy="300" r="100" fill="none" stroke="#f87171" stroke-width="12" stroke-dasharray="400 628" stroke-dashoffset="157" stroke-linecap="round" transform="rotate(-90 900 300)"/>
  <text x="900" y="295" font-family="system-ui, -apple-system, sans-serif" font-size="48" font-weight="800" fill="white" text-anchor="middle">58</text>
  <text x="900" y="325" font-family="system-ui, -apple-system, sans-serif" font-size="14" font-weight="600" fill="#f87171" text-anchor="middle">NEEDS FIX</text>

  <!-- Issues list -->
  <text x="730" y="450" font-family="system-ui, -apple-system, sans-serif" font-size="12" fill="white" opacity="0.4">Issues found:</text>
  <circle cx="745" cy="475" r="4" fill="#f87171"/>
  <text x="755" y="479" font-family="system-ui, -apple-system, sans-serif" font-size="11" fill="white" opacity="0.6">Missing keywords</text>
  <circle cx="745" cy="500" r="4" fill="#f87171"/>
  <text x="755" y="504" font-family="system-ui, -apple-system, sans-serif" font-size="11" fill="white" opacity="0.6">No quantified metrics</text>

  <!-- After score -->
  <rect x="700" y="540" width="400" height="60" rx="12" fill="white" opacity="0.03"/>
  <text x="730" y="578" font-family="system-ui, -apple-system, sans-serif" font-size="12" fill="white" opacity="0.4">After CraftlyCV fixes →</text>
  <text x="870" y="578" font-family="system-ui, -apple-system, sans-serif" font-size="20" font-weight="800" fill="#34d399">87 ATS Score</text>
  <rect x="700" y="595" width="400" height="5" rx="2.5" fill="white" opacity="0.1"/>
  <rect x="700" y="595" width="348" height="5" rx="2.5" fill="#34d399"/>
</svg>
